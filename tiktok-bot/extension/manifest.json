{
    "manifest_version": 3,
    "name": "TikTok → Recettes Magiques",
    "version": "1.0",
    "description": "Détecte les favoris TikTok et les envoie vers WordPress automatiquement",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://www.tiktok.com/*",
        "http://localhost:3456/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.tiktok.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "TikTok → WordPress"
    }
}